#!/usr/bin/env php
<?php

declare(strict_types=1);

include_once dirname(__DIR__) . '/src/config.php';
require_once $librenms_base . '/vendor/autoload.php';

use Weathermap\Map\WeatherMap;

if (!wm_module_checks()) { die ("Quitting: Module checks failed.\n"); }

$configfile  = 'weathermap.conf';
$htmlfile    = '';
$imagefile   = '';
$dumpafter   = 0;
$dumpstats   = 0;
$randomdata  = 0;
$dumpconfig  = '';
$defines     = [];
$daemon_socket = '';

// Pull runtime settings from LibreNMS config where available.
if (class_exists('\LibreNMS\Config')) {
    $rrdtool   = \LibreNMS\Config::get('rrdtool', $rrdtool);
    $rrd_dir   = \LibreNMS\Config::get('rrd_dir', $librenms_base . '/rrd');
    $rrdcached = \LibreNMS\Config::get('rrdcached', '');
} else {
    $rrd_dir   = $librenms_base . '/rrd';
    $rrdcached = '';
}

$opts = getopt('', [
    'version', 'help',
    'config:', 'output:', 'htmloutput:',
    'image-uri:', 'base-href:',
    'define:', 'no-warn:',
    'daemon:',  'dumpconfig:',
    'debug', 'uberdebug',
    'no-data', 'sizedebug', 'randomdata',
    'bulge', 'dumpafter', 'stats',
]);

$options_output = [];

if (isset($opts['version'])) {
    print 'PHP Network Weathermap v' . $WEATHERMAP_VERSION . "\n";
    exit();
}

if (isset($opts['help'])) {
    print 'PHP Network Weathermap v' . $WEATHERMAP_VERSION . "\n";
    print "Copyright Howard Jones, 2005-2020 howie@thingy.com\nReleased under the MIT License\n\n";
    print "Usage: php weathermap [options]\n\n";
    print " --config {filename}      -  config file to read. Default weathermap.conf\n";
    print " --output {filename}      -  image file to write. Default weathermap.png\n";
    print " --htmloutput {filename}  -  HTML file to write\n\n";
    print " --base-href {uri}        -  URI for Weathermap, e.g. /weathermap/\n";
    print " --image-uri {uri}        -  URI prefix for <img> tags in HTML\n";
    print " --bulge                  -  enable link-bulging mode\n\n";
    print " --define name=value      -  define internal variable (like global SET)\n";
    print " --no-warn {codes}        -  suppress comma-separated warning codes\n\n";
    print " --no-data                -  skip data reading (grey map)\n";
    print " --randomdata             -  use random data instead of live data\n";
    print " --debug                  -  enable debug output\n";
    print " --uberdebug              -  enable all trace messages\n";
    print " --dumpafter              -  dump internal PHP structures\n";
    print " --dumpconfig {filename}  -  write parsed config to file\n";
    print " --stats                  -  dump feature usage statistics\n\n";
    print " --daemon {path}          -  rrdcached socket (overrides LibreNMS config)\n\n";
    print " --help                   -  show this help\n";
    print " --version                -  show version number\n";
    exit();
}

if (isset($opts['config']))      { $configfile  = $opts['config']; }
if (isset($opts['output']))      { $imagefile   = $opts['output']; }
if (isset($opts['htmloutput']))  { $htmlfile    = $opts['htmloutput']; }
if (isset($opts['dumpconfig']))  { $dumpconfig  = $opts['dumpconfig']; }
if (isset($opts['daemon']))      { $daemon_socket = $opts['daemon']; }
if (isset($opts['dumpafter']))   { $dumpafter   = 1; }
if (isset($opts['randomdata']))  { $randomdata  = 1; }
if (isset($opts['stats']))       { $dumpstats   = 1; }

if (isset($opts['image-uri']))   { $options_output['imageuri']  = $opts['image-uri']; }
if (isset($opts['base-href']))   { $options_output['basehref']  = $opts['base-href']; }
if (isset($opts['no-data']) || isset($opts['sizedebug'])) { $options_output['sizedebug'] = true; }
if (isset($opts['bulge']))       { $options_output['widthmod']  = true; }

if (isset($opts['uberdebug'])) {
    $weathermap_debug_suppress = [];
}
if (isset($opts['uberdebug']) || isset($opts['debug'])) {
    $options_output['debugging'] = true;
    $weathermap_debugging = true;
}

if (isset($opts['no-warn'])) {
    foreach (explode(',', $opts['no-warn']) as $code) {
        $weathermap_error_suppress[] = strtoupper(trim($code));
    }
}

if (isset($opts['define'])) {
    $raw = is_array($opts['define']) ? $opts['define'] : [$opts['define']];
    foreach ($raw as $def) {
        if (preg_match("/^([^=]+)=(.*)\s*$/", $def, $m)) {
            $defines[$m[1]] = $m[2];
        } else {
            print "WARNING: --define format is: --define name=value\n";
        }
    }
}

// set this BEFORE we create the map object, so we get the debug output from Reset(), as well
if(isset($options_output['debugging']) && $options_output['debugging']) 
{
	$weathermap_debugging=TRUE;
	wm_debug("------------------------------------\n");
	wm_debug("Starting PHP-Weathermap run, with config: $configfile\n");
	wm_debug("------------------------------------\n");
}

$map=new WeatherMap;
$map->rrdtool = $rrdtool;
$map->context="cli";

// Pass rrdcached socket via hint: CLI --daemon takes priority over LibreNMS config.
$resolved_socket = $daemon_socket !== '' ? $daemon_socket : $rrdcached;
if ($resolved_socket !== '') {
    $map->add_hint('rrd_daemon', $resolved_socket);
}

// now stuff in all the others, that we got from getopts
foreach ($options_output as $key=>$value)
{
	$map->$key = $value;
	// $map->add_hint($key,$value);
}

$weathermap_map = $configfile;

if ($map->ReadConfig($configfile))
{
	// allow command-lines to override the config file, but provide a default if neither are present
	if ($imagefile == '')
	{
		if ($map->imageoutputfile == '') { $imagefile="weathermap.png"; }
		else { $imagefile=$map->imageoutputfile; }
	}

	if ($htmlfile == '')
	{
		if ($map->htmloutputfile != '') { $htmlfile = $map->htmloutputfile; }
	}

    // feed in any command-line defaults, so that they appear as if SET lines in the config
    
    // XXX FIXME
    foreach ($defines as $hintname=>$hint)
    {
        $map->add_hint($hintname,$hint);
    }
	
	// now stuff in all the others, that we got from getopts
	foreach ($options_output as $key=>$value)
	{
		// $map->$key = $value;
		$map->add_hint($key,$value);
	}

	// Get rrd default path
    $rrdbase = $map->get_hint('rrd_default_path');

	// Fall back to rrd_dir from LibreNMS config if not set in map config or --chdir
    if ($rrdbase == '') {
        $rrdbase = isset($chdir) ? $chdir : $rrd_dir;
        $map->add_hint('rrd_default_path', $rrdbase);
    }

    if ( (isset($options_output['sizedebug']) && ! $options_output['sizedebug']) || (!isset($options_output['sizedebug'])) )
	{
		if ($randomdata == 1) { $map->RandomData(); }
		else { $map->ReadData(); }
	}

	# exit();
	
	if ($imagefile != '')
	{
		$map->DrawMap($imagefile);
		$map->imagefile=$imagefile;
	}

	if ($htmlfile != '')
	{
		wm_debug("Writing HTML to $htmlfile\n");
		
		$fd=fopen($htmlfile, 'w');
		fwrite($fd,
			'<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html xmlns="http://www.w3.org/1999/xhtml"><head>');
		fwrite($fd,"<base href=\"$map->basehref\">");
		if($map->htmlstylesheet != '') fwrite($fd,'<link rel="stylesheet" type="text/css" href="'.$map->htmlstylesheet.'" />');
		fwrite($fd,'<meta http-equiv="refresh" content="300" /><title>' . $map->ProcessString($map->title, $map) . '</title></head><body>');

		if ($map->htmlstyle == "overlib")
		{
			fwrite($fd,
				"<div id=\"overDiv\" style=\"position:absolute; visibility:hidden; z-index:1000;\"></div>\n");
			fwrite($fd,
				"<script type=\"text/javascript\" src=\"overlib.js\"><!-- overLIB (c) Erik Bosrup --></script> \n");
		}

		fwrite($fd, $map->MakeHTML());
		fwrite($fd,
			'<hr /><span id="byline">Network Map created with <a href="http://www.network-weathermap.com/?vs='
			. $WEATHERMAP_VERSION . '">PHP Network Weathermap v' . $WEATHERMAP_VERSION
			. '</a></span></body></html>');
		fclose ($fd);
	}

	if ($dumpconfig != '')
		$map->WriteConfig($dumpconfig);

	if ($dumpstats != '')
		$map->DumpStats();

	if ($dumpafter == 1)
		print_r ($map);

}
else { die ("\n\nCould not read Weathermap config file. No output produced. Maybe try --help?\n"); }


