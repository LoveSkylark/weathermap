#!/usr/bin/env php
<?php

if (php_sapi_name() !== 'cli') {
    echo "ERROR: map-poller must be run from the command line.\n";
    exit(1);
}

// -d option for debug
$options = getopt('d');
$debug   = isset($options['d']);

if ($debug) {
    ini_set('display_errors', 1);
    ini_set('display_startup_errors', 1);
    ini_set('log_errors', 1);
    echo "DEBUG mode on\n";
} else {
    ini_set('display_startup_errors', 0);
    ini_set('log_errors', 0);
    ini_set('error_reporting', 0);
}

// ── Bootstrap ────────────────────────────────────────────────────────────────
include_once dirname(__DIR__) . '/src/config.php';

require_once $librenms_base . '/vendor/autoload.php';

$app    = require $librenms_base . '/bootstrap/app.php';
$kernel = $app->make(\Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();

// ── Read config via LibreNMS\Config ──────────────────────────────────────────
$rrdcached = \LibreNMS\Config::get('rrdcached', '');
$rrd_dir   = \LibreNMS\Config::get('rrd_dir', $librenms_base . '/rrd');
$output_dir = $plugin_dir . '/public/output';     // web-accessible via symlink
$basehref   = '/plugins/Weathermap/';

if (! is_dir($output_dir)) {
    mkdir($output_dir, 0755, true);
}

// ── Run weathermap for every config file ──────────────────────────────────────
if (! is_dir($conf_dir)) {
    echo "ERROR: configs directory not found at $conf_dir\n";
    exit(1);
}

$dh = opendir($conf_dir);
if ($dh === false) {
    echo "ERROR: cannot open configs directory $conf_dir\n";
    exit(1);
}

while (($file = readdir($dh)) !== false) {
    // Skip dot entries, .htaccess, and index.php
    if ($file === '.' || $file === '..' || $file === '.htaccess' || $file === 'index.php') {
        continue;
    }

    $mapname = pathinfo($file, PATHINFO_FILENAME);
    $cmd = escapeshellcmd(PHP_BINARY) . ' ' . escapeshellarg($plugin_dir . '/bin/weathermap')
        . ' --config '     . escapeshellarg("$conf_dir/$file")
        . ' --base-href '  . escapeshellarg($basehref)
        . ' --output '     . escapeshellarg("$output_dir/$mapname.png")
        . ' --htmloutput ' . escapeshellarg("$output_dir/$mapname.html");

    if ($rrdcached !== '') {
        $cmd .= ' --daemon ' . escapeshellarg($rrdcached);
        // If rrdcached is not a Unix socket, weathermap also needs --chdir
        if (! str_starts_with($rrdcached, 'unix')) {
            $cmd .= " --chdir ''";
        }
    } else {
        $cmd .= ' --chdir ' . escapeshellarg($rrd_dir);
    }

    if ($debug) {
        echo "Running: $cmd\n";
    }

    $fp = popen($cmd, 'r');
    while (! feof($fp)) {
        echo fgets($fp);
    }
    pclose($fp);
}

closedir($dh);
